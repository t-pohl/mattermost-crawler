# Mattermost-Zugangsdaten – EINFACHER Fall: genau eine Instanz.
# --------------------------------------------------------------
# Login erfolgt über die native Mattermost-REST-API mit Benutzername/E-Mail
# und Passwort (kein SSO, kein Browser nötig). Die erhaltene Session wird in
# .mmauth.json gespeichert und bei späteren Läufen wiederverwendet.
#
# Für MEHRERE Instanzen siehe config.example.toml und das Profil-System
# (--profile). Diese .env wird nur genutzt, wenn KEINE config.toml existiert.

# E-Mail-Adresse ODER Benutzername (das Feld "E-Mail oder Benutzername").
MM_USERNAME=

# Passwort.
MM_PASSWORD=

# Basis-URL der Mattermost-Instanz (ohne abschließenden Slash; wird sonst
# automatisch entfernt). Die API liegt unter <MM_BASE_URL>/api/v4.
MM_BASE_URL=https://mm.schulen-saar.de
